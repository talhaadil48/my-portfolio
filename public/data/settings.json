        {
            "name": "Urdu",
            "id": "ur",
            "flagUrl": "images/flags/pk.png"
        }
    ],

    "supportedThemes": [
        {
            "id": "dark",
            "icon": "fa-solid fa-moon",
            "dark": true,
            "locales": {
                "en": {"name": "Dark Mode"},
                "ur": {"name": "ڈارک موڈ"}
            }
        },
        {
            "id": "light",
            "icon": "fa-solid fa-sun",
            "dark": false,
            "locales": {
                "en": {"name": "Light Mode"},
                "ur": {"name": "لائٹ موڈ"}
            }
        }
    ],

