{
    "developerSettings": {
        "debugMode": false,
        "fakeEmailRequests": false,
        "stayOnThePreloaderScreen": false,
        "version": "2.0.3"
    },

    "preloaderSettings": {
        "enabled": true,
        "title": "Talha Adil <strong>Portfolio</strong>",
        "subtitle": "Full Stack & Machine Learning Engineer",
        "logoOffset": {
            "right": 14,
            "top": 2,
            "bottom": 0
        }
